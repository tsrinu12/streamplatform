# Application Configuration
NODE_ENV=development
APP_PORT=3000
APP_NAME=StreamPlatform
LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=streamuser
DB_PASSWORD=streampass
DB_NAME=streamdb
DB_SSL=false

# MongoDB Configuration
MONGO_URI=mongodb://streamuser:streampass@localhost:27017/streamdb
MONGO_USER=streamuser
MONGO_PASSWORD=streampass
MONGO_PORT=27017

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# API Keys and Secrets
API_KEY=your-api-key
API_SECRET=your-api-secret

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=streamplatform-videos

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@streamplatform.com

# Video Processing
FFMPEG_PATH=/usr/bin/ffmpeg
VIDEO_TEMP_DIR=/tmp/videos
VIDEO_UPLOAD_DIR=/data/videos
MAX_VIDEO_SIZE=5000

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PREFIX=streamplatform

# Elasticsearch Configuration
ELASTIC_HOST=localhost
ELASTIC_PORT=9200
ELASTIC_USER=elastic
ELASTIC_PASSWORD=changeme

# Service URLs
AUTH_SERVICE_URL=http://localhost:3001
VIDEO_SERVICE_URL=http://localhost:3002
STREAM_SERVICE_URL=http://localhost:3003
ANALYTICS_SERVICE_URL=http://localhost:3004

# Feature Flags
FEATURE_LIVE_STREAMING=true
FEATURE_ANALYTICS=true
FEATURE_RECOMMENDATIONS=true
FEATURE_CDN=false

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_DIR=/var/log/streamplatform
LOG_MAX_SIZE=10m
LOG_MAX_FILES=10

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000
