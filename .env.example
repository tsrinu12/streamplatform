# ==============================================================================
# StreamPlatform Environment Variables Template
# ==============================================================================
# IMPORTANT: Copy this file to .env and update ALL values before deployment.
# NEVER commit .env file to version control - it is in .gitignore.
# Generate strong random values for all secrets using: openssl rand -hex 32
# ==============================================================================

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
NODE_ENV=production
APP_PORT=3000
APP_NAME=StreamPlatform
LOG_LEVEL=warn

# ==============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==============================================================================
# Use environment-specific connection strings for each environment
DB_HOST=localhost
DB_PORT=5432
DB_USER=streamuser
DB_PASSWORD=<GENERATE_STRONG_PASSWORD>
DB_NAME=streamdb
DB_SSL=true
DB_POOL_SIZE=20
DB_MAX_CONNECTIONS=100

# ==============================================================================
# MONGODB CONFIGURATION
# ==============================================================================
# Use replica set connection string for production
MONGO_URI=mongodb://localhost:27017/streamdb?replicaSet=rs0&ssl=true
MONGO_USER=streamuser
MONGO_PASSWORD=<GENERATE_STRONG_PASSWORD>
MONGO_PORT=27017
MONGO_AUTH_DB=admin

# ==============================================================================
# REDIS CONFIGURATION
# ==============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<GENERATE_STRONG_PASSWORD>
REDIS_DB=0
REDIS_TLS_ENABLED=true
REDIS_CLUSTER_ENABLED=false

# ==============================================================================
# JWT CONFIGURATION
# ==============================================================================
# Generate using: openssl rand -base64 64
JWT_SECRET=<GENERATE_JWT_SECRET>
JWT_EXPIRATION=1h
REFRESH_TOKEN_EXPIRATION=7d
JWT_ALGORITHM=RS256

# ==============================================================================
# AWS CONFIGURATION
# ==============================================================================
# For production, use IAM roles or OIDC instead of access keys
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<AWS_SECRET_ACCESS_KEY>
AWS_S3_BUCKET=streamplatform-videos
AWS_S3_REGION=us-east-1
AWS_CLOUDFRONT_DOMAIN=<YOUR_CLOUDFRONT_DOMAIN>

# ==============================================================================
# EMAIL CONFIGURATION (SMTP)
# ==============================================================================
SMTP_HOST=<YOUR_SMTP_HOST>
SMTP_PORT=587
SMTP_USER=<YOUR_SMTP_USER>
SMTP_PASSWORD=<YOUR_SMTP_PASSWORD>
SMTP_FROM=noreply@streamplatform.com
SMTP_SECURE=true
SMTP_TLS=true

# ==============================================================================
# VIDEO PROCESSING
# ==============================================================================
FFMPEG_PATH=/usr/bin/ffmpeg
VIDEO_TEMP_DIR=/tmp/videos
VIDEO_UPLOAD_DIR=/data/videos
MAX_VIDEO_SIZE=5000
VIDEO_TRANSCODE_PRESET=medium
VIDEO_OUTPUT_FORMAT=mp4

# ==============================================================================
# KAFKA CONFIGURATION
# ==============================================================================
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PREFIX=streamplatform
KAFKA_CONSUMER_GROUP=streamplatform-group
KAFKA_SSL_ENABLED=false
KAFKA_SASL_ENABLED=false

# ==============================================================================
# ELASTICSEARCH CONFIGURATION
# ==============================================================================
ELASTIC_HOST=localhost
ELASTIC_PORT=9200
ELASTIC_USER=elastic
ELASTIC_PASSWORD=<GENERATE_STRONG_PASSWORD>
ELASTIC_TLS_ENABLED=true
ELASTIC_API_KEY=<ELASTIC_API_KEY>

# ==============================================================================
# SERVICE URLS (Internal Kubernetes DNS)
# ==============================================================================
# For Kubernetes: use service names as DNS
AUTH_SERVICE_URL=http://auth-service:3001
VIDEO_SERVICE_URL=http://video-service:3002
STREAM_SERVICE_URL=http://stream-service:3003
ANALYTICS_SERVICE_URL=http://analytics-service:3004
RECOMMENDATION_SERVICE_URL=http://recommendation-service:3005

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
FEATURE_LIVE_STREAMING=true
FEATURE_ANALYTICS=true
FEATURE_RECOMMENDATIONS=true
FEATURE_CDN=true
FEATURE_SUBTITLES=true
FEATURE_TRANSCODING=true

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
CORS_ORIGINS=https://streamplatform.com,https://app.streamplatform.com
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH
CORS_MAX_AGE=86400

# ==============================================================================
# RATE LIMITING
# ==============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_UPLOADS=10
RATE_LIMIT_BYPASS_TOKEN=<BYPASS_TOKEN>

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_DIR=/var/log/streamplatform
LOG_MAX_SIZE=10m
LOG_MAX_FILES=10
LOG_FORMAT=json
LOG_LEVEL=warn
LOG_SOURCE_MAPS=false

# ==============================================================================
# CACHE CONFIGURATION
# ==============================================================================
CACHE_TTL=3600
CACHE_MAX_SIZE=1000
CACHE_REDIS_ENABLED=true

# ==============================================================================
# SECURITY CONFIGURATION
# ==============================================================================
SESSION_SECRET=<GENERATE_SESSION_SECRET>
ENCRYPTION_KEY=<GENERATE_ENCRYPTION_KEY>
CSRF_TOKEN_SECRET=<GENERATE_CSRF_SECRET>
ALLOWED_HOSTS=streamplatform.com,*.streamplatform.com
SECURE_COOKIES=true
HSTS_ENABLED=true

# ==============================================================================
# MONITORING & OBSERVABILITY
# ==============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=streamplatform
PROMETHEUS_SCRAPE_ENABLED=true
GRAFANA_URL=https://grafana.streamplatform.com

# ==============================================================================
# CDN & STORAGE
# ==============================================================================
CDN_ENABLED=true
CDN_PROVIDER=cloudfront
STORAGE_PROVIDER=s3
STORAGE_ENDPOINT=s3.amazonaws.com

# ==============================================================================
# AI & RECOMMENDATION SERVICE
# ==============================================================================
AI_MODEL_ENDPOINT=<AI_MODEL_API_URL>
AI_API_KEY=<AI_MODEL_API_KEY>
RECOMMENDATION_ALGORITHM=collaborative-filtering
RECOMMENDATION_BATCH_SIZE=100

# ==============================================================================
# SUBTITLE & TRANSLATION
# ==============================================================================
SUBTITLE_API_KEY=<SUBTITLE_API_KEY>
TRANSLATION_API_KEY=<TRANSLATION_API_KEY>
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de,hi,zh,ja
